{
  "name": "rental-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @rental/mobile start",
    "admin": "yarn workspace @rental/admin dev",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/supabase/src/types.ts",
    "db:diff": "supabase db diff",
    "db:push": "supabase db push",
    "fn:serve": "supabase functions serve --env-file supabase/functions/.env",
    "fn:deploy:all": "supabase functions deploy send-otp && supabase functions deploy verify-otp && supabase functions deploy razorpay-create-order && supabase functions deploy razorpay-webhook && supabase functions deploy notify-owner",
    "fn:deploy": "supabase functions deploy"
  },
  "devDependencies": {
    "supabase": "^1.200.0",
    "typescript": "^5.4.0"
  }
}
